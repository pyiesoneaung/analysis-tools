# === OPTION 1: Twelve Data (recommended, free tier available) ===
# Sign up at https://twelvedata.com
TWELVEDATA_API_KEY=d73a545d5bb645a6be38d5f1d2bde924

# === OPTION 2: Alpha Vantage (free) ===
# Sign up at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# === OPTION 3: Polygon.io ===
# Sign up at https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# ─────────────────────────────────────────────
# Which provider to use: "twelvedata" | "alphavantage" | "polygon" | "demo"
# Use "demo" for simulated data (no API key needed)
DATA_PROVIDER=twelvedata

# Cache TTL in seconds (default: 60s for live, 300s for historical)
CACHE_TTL_LIVE=60
CACHE_TTL_HIST=300
